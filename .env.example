# ─── Azure Identity ──────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=rg-omega-sare
AZURE_LOCATION=westeurope

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Google Gemini
GOOGLE_API_KEY=your-gemini-api-key-here

# GitHub (for Knowledge API Search)
GITHUB_PAT=your-github-personal-access-token-here

# Option B: Azure OpenAI (leave OPENAI_API_KEY blank and fill these)
AZURE_OPENAI_ENDPOINT=https://<your-instance>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─── Backend / Database ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./omega.db

# ─── Integrations ────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your-confluence-token

# ─── Switch: local subprocess vs Azure Container Instances ───────────────────
USE_ACI=false
